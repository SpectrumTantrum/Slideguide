# SlideGuide Environment Configuration

# ── Provider Selection ───────────────────────────────────────────────────────
# Which backend to use for each capability
LLM_PROVIDER=openrouter              # "openrouter" (cloud) or "lmstudio" (local)
EMBEDDING_PROVIDER=openai            # "openai" (cloud) or "lmstudio" (local)
VISION_PROVIDER=openrouter           # "openrouter" (cloud) or "lmstudio" (local)

# ── OpenRouter API (LLM gateway for chat/tool use) ───────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── OpenAI API (embeddings only - not routed through OpenRouter) ─────────────
OPENAI_API_KEY=sk-...

# ── LM Studio (local models) ────────────────────────────────────────────────
# Leave model fields empty to auto-discover from LM Studio
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_PRIMARY_MODEL=              # auto-discovered if empty
LMSTUDIO_ROUTING_MODEL=              # falls back to primary if empty
LMSTUDIO_EMBEDDING_MODEL=            # auto-discovered if empty

# ── Model Configuration (OpenRouter format, used when LLM_PROVIDER=openrouter)
PRIMARY_MODEL=anthropic/claude-sonnet-4
ROUTING_MODEL=anthropic/claude-haiku-4
VISION_MODEL=anthropic/claude-sonnet-4
FALLBACK_MODEL=deepseek/deepseek-chat-v3
EMBEDDING_MODEL=text-embedding-3-small

# ── Supabase ───────────────────────────────────────────────────────────────────
# Copy these from the output of `supabase start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key            # reserved for future frontend auth
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Tesseract OCR ────────────────────────────────────────────────────────────
TESSERACT_CMD=tesseract

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SlideGuide
APP_URL=https://github.com/yourusername/slideguide
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Cost Control ─────────────────────────────────────────────────────────────
MAX_TOKENS_PER_SESSION=100000
MAX_UPLOAD_SIZE_MB=50
