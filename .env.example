# SlideGuide Environment Configuration

# OpenRouter API (LLM gateway for chat/tool use)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI API (embeddings only - not routed through OpenRouter)
OPENAI_API_KEY=sk-...

# Model Configuration
PRIMARY_MODEL=anthropic/claude-sonnet-4
ROUTING_MODEL=anthropic/claude-haiku-4
VISION_MODEL=anthropic/claude-sonnet-4
FALLBACK_MODEL=deepseek/deepseek-chat-v3
EMBEDDING_MODEL=text-embedding-3-small

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/slideguide

# ChromaDB
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# Tesseract OCR
TESSERACT_CMD=tesseract

# Application
APP_NAME=SlideGuide
APP_URL=https://github.com/yourusername/slideguide
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# Cost Control
MAX_TOKENS_PER_SESSION=100000
MAX_UPLOAD_SIZE_MB=50
